# ========================================================
# Aura — Backend Environment Config
# ========================================================

# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-nano

# ── Auth0 Tenant & API ──────────────────────────────────
# Domain found in: Auth0 Dashboard → Settings → Tenant Settings
AUTH0_DOMAIN=dev-xxxxx.us.auth0.com

# The Audience identifier for the Aura API resource
# Dashboard → Applications → APIs → Aura API → Identifier
AUTH0_AUDIENCE=https://aura-api

# The name of the social connection in Auth0 configured for Token Vault
AUTH0_TOKEN_VAULT_CONNECTION=github

# ── Auth0 Aura Frontend App (Regular Web Application) ───
# Used for browser-facing user auth flows and connected accounts
# Copy from: Auth0 Dashboard → Applications → Aura Frontend
AUTH0_FRONTEND_CLIENT_ID=
AUTH0_FRONTEND_CLIENT_SECRET=

# ── Auth0 Aura Backend App (Machine to Machine) ───────
# Used for backend-to-Auth0 secure service calls (e.g. mgmt token)
# Copy from: Auth0 Dashboard → Applications → Aura Backend
AUTH0_BACKEND_M2M_CLIENT_ID=
AUTH0_BACKEND_M2M_CLIENT_SECRET=

# ── GitHub ────────────────────────────────────────────
GITHUB_API_BASE=https://api.github.com

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite:///./aura.db

# ── App & Security ────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
DEFAULT_USER_SUB=demo-user
