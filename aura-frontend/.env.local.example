# ========================================================
# Aura — Frontend Environment Config (Public)
# ========================================================

# The base URL for the Aura FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth0 Tenant Domain
# dashboard → Settings → Tenant Settings
NEXT_PUBLIC_AUTH0_DOMAIN=dev-xxxxx.us.auth0.com

# --------------------------------------------------------
# IMPORTANT: This MUST be the client ID of the "Aura Frontend" 
# Regular Web Application, NOT the Backend M2M app.
# --------------------------------------------------------
NEXT_PUBLIC_AUTH0_CLIENT_ID=

# The API identifier (Audience) for the Aura API
NEXT_PUBLIC_AUTH0_AUDIENCE=https://aura-api
